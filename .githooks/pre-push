#!/usr/bin/env bash
set -euo pipefail

if [[ "${SKIP_GIT_HOOKS:-}" == "1" ]]; then
  exit 0
fi

if ! command -v act >/dev/null 2>&1; then
  echo "ERROR: 'act' is required for git hooks but was not found." >&2
  echo "Please install it: brew install act" >&2
  exit 1
fi

echo "[pre-push] running unit tests via act..."
act -j go-unit-tests
act -j node-unit-tests
act -j playwright-tests

{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["local", "staging", "stage", "prod"]
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": ["name"]
          }
        },
        "featureFlags": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "loopPolicyConfig": { "type": "boolean" },
            "operatorOverrides": { "type": "boolean" },
            "auditStream": { "type": "boolean" },
            "interactiveAttach": { "type": "boolean" }
          }
        }
      },
      "required": ["environment", "imagePullSecrets", "featureFlags"]
    },
    "etcd": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "endpoints": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^https?://"
          },
          "minItems": 1
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "caSecretName": { "type": "string" },
            "certSecretName": { "type": "string" }
          },
          "required": ["enabled", "caSecretName", "certSecretName"]
        }
      },
      "required": ["endpoints", "tls"]
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "existingSecret": { "type": "string" },
        "create": { "type": "boolean" },
        "managed": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "gitPat": { "type": "string" },
            "runtimeCredentials": { "type": "string" }
          },
          "required": ["gitPat", "runtimeCredentials"]
        },
        "keys": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "gitPat": { "type": "string", "minLength": 1 },
            "runtimeCredentials": { "type": "string", "minLength": 1 }
          },
          "required": ["gitPat", "runtimeCredentials"]
        }
      },
      "required": ["existingSecret", "create", "managed", "keys"],
      "allOf": [
        {
          "if": {
            "properties": {
              "create": { "const": true }
            },
            "required": ["create"]
          },
          "then": {
            "properties": {
              "existingSecret": { "maxLength": 0 }
            }
          }
        }
      ]
    },
    "core": { "$ref": "#/definitions/componentConfigWithLoopPolicy" },
    "api": { "$ref": "#/definitions/componentConfigWithService" },
    "console": { "$ref": "#/definitions/componentConfigWithService" },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" }
      },
      "required": ["create"]
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" }
  },
  "required": ["global", "etcd", "secrets", "core", "api", "console", "rbac", "nameOverride", "fullnameOverride"],
  "definitions": {
    "componentImage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["repository", "tag", "pullPolicy"]
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      },
      "required": ["create", "name"]
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "required": ["type", "port"]
    },
    "envVar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "value": { "type": "string" }
      },
      "required": ["name", "value"]
    },
    "resourceRequirements": {
      "type": "object"
    },
    "loopPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxAttempts": {
          "type": "integer",
          "minimum": 1
        },
        "backoffInitial": {
          "type": "string",
          "pattern": "^[0-9]+(ms|s|m|h)$"
        },
        "backoffMax": {
          "type": "string",
          "pattern": "^[0-9]+(ms|s|m|h)$"
        },
        "timeout": {
          "type": "string",
          "pattern": "^[0-9]+(ms|s|m|h)$"
        },
        "terminateOnError": { "type": "boolean" }
      },
      "required": ["maxAttempts", "backoffInitial", "backoffMax", "timeout", "terminateOnError"]
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "targetMemoryUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "scaleUpStabilizationWindowSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "scaleDownStabilizationWindowSeconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "targetCPUUtilizationPercentage",
        "targetMemoryUtilizationPercentage",
        "scaleUpStabilizationWindowSeconds",
        "scaleDownStabilizationWindowSeconds"
      ]
    },
    "replicaTemplate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serviceAccountName": { "type": "string" },
        "resources": { "$ref": "#/definitions/resourceRequirements" },
        "nodeSelector": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "tolerations": {
          "type": "array",
          "items": { "type": "object" }
        },
        "env": {
          "type": "array",
          "items": { "$ref": "#/definitions/envVar" }
        }
      },
      "required": ["serviceAccountName", "resources", "nodeSelector", "tolerations", "env"]
    },
    "componentConfigWithLoopPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "autoscaling": { "$ref": "#/definitions/autoscaling" },
        "image": { "$ref": "#/definitions/componentImage" },
        "replicaImage": { "$ref": "#/definitions/componentImage" },
        "serviceAccount": { "$ref": "#/definitions/serviceAccount" },
        "loopPolicy": { "$ref": "#/definitions/loopPolicy" },
        "replicaTemplate": { "$ref": "#/definitions/replicaTemplate" },
        "resources": { "$ref": "#/definitions/resourceRequirements" },
        "env": {
          "type": "array",
          "items": { "$ref": "#/definitions/envVar" }
        }
      },
      "required": ["enabled", "replicaCount", "autoscaling", "image", "replicaImage", "serviceAccount", "loopPolicy", "replicaTemplate", "resources", "env"]
    },
    "componentConfigWithService": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "apiBaseUrl": { "type": "string", "minLength": 1 },
        "showComingSoonProviders": { "type": "boolean" },
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "autoscaling": { "$ref": "#/definitions/autoscaling" },
        "image": { "$ref": "#/definitions/componentImage" },
        "service": { "$ref": "#/definitions/service" },
        "serviceAccount": { "$ref": "#/definitions/serviceAccount" },
        "resources": { "$ref": "#/definitions/resourceRequirements" },
        "env": {
          "type": "array",
          "items": { "$ref": "#/definitions/envVar" }
        }
      },
      "required": ["enabled", "replicaCount", "autoscaling", "image", "service", "serviceAccount", "resources", "env"]
    }
  }
}

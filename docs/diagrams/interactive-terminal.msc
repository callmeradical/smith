msc {
  hscale = "1.5";

  client [label="smithctl / Console"],
  api [label="smith-api"],
  k8s [label="Kubernetes"],
  replica [label="smith-replica"];

  client -> api [label="GET /v1/loops/{id}/runtime"];
  api -> k8s [label="List Pods (label: loop_id)"];
  api <- k8s [label="Pod info"];
  client <- api [label="200 OK (pod_name, attachable)"];

  client -> api [label="POST /v1/loops/{id}/control/attach"];
  api -> api [label="Verify Actor"];
  client <- api [label="200 OK (attached)"];

  client -> api [label="POST /v1/loops/{id}/control/command"];
  api -> k8s [label="POST pods/exec"];
  k8s -> replica [label="Execute command"];
  k8s <- replica [label="stdout/stderr/exit_code"];
  api <- k8s [label="Exec response"];
  client <- api [label="200 OK (result)"];

  client -> api [label="POST /v1/loops/{id}/control/detach"];
  client <- api [label="200 OK (detached)"];
}

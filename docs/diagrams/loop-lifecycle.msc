msc {
  hscale = "1.5";

  client [label="smithctl / Console"],
  api [label="smith-api"],
  core [label="smith-core"],
  etcd [label="etcd"],
  k8s [label="Kubernetes"],
  replica [label="smith-replica"];

  client -> api [label="POST /v1/loops"];
  api -> etcd [label="Create loop record (status: unresolved)"];
  api <- etcd [label="OK"];
  client <- api [label="201 Created (loop_id)"];

  --- [label="Orchestration Loop"];

  core -> etcd [label="Watch /loops"];
  core <- etcd [label="New loop (unresolved)"];
  core -> etcd [label="Acquire Lock"];
  core <- etcd [label="Lock Acquired"];
  core -> k8s [label="Create Job (replica)"];
  k8s -> replica [label="Spawn Pod"];
  core -> etcd [label="Update status: overwriting"];

  --- [label="Execution"];

  replica -> etcd [label="Watch /loops/{id}"];
  replica -> etcd [label="Append Journal"];
  replica -> etcd [label="Update status: synced"];

  --- [label="Lifecycle Control"];

  client -> api [label="GET /v1/loops/{id}"];
  api -> etcd [label="Fetch state"];
  api <- etcd [label="State"];
  client <- api [label="200 OK"];

  client -> api [label="DELETE /v1/loops/{id}"];
  api -> etcd [label="Update status: cancelled"];
  api <- etcd [label="OK"];
  client <- api [label="200 OK"];
}

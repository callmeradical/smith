+	}
+
+	var stdout, stderr bytes.Buffer
+	code := run([]string{"--prd", "validate", jsonPath}, strings.NewReader(""), &stdout, &stderr)
+	if code != 0 {
+		t.Fatalf("expected validation warning code=0, got %d stderr=%s stdout=%s", code, stderr.String(), stdout.String())

+	s.handleLoopDetach(rec, req, "loop-auth")
+
+	if rec.Code != http.StatusUnauthorized {
+		t.Fatalf("expected 401 for unauthorized detach, got %d body=%s", rec.Code, rec.Body.String())
+	}
+	if stateCalls != 0 {

	assertDiagnosticCode(t, report.Errors, PRDDiagnosticMissingQualityGates)
}

func TestValidatePRDReportRejectsNonCanonicalStatus(t *testing.T) {
	prd := PRD{
		Version:  1,
		Project:  "Validation",

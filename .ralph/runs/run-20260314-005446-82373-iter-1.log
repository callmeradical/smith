				Status:             "open",
				Description:        "desc",
				AcceptanceCriteria: []string{"one"},
			},
			{
				ID:                 "US-001",
				Title:              "Duplicate story",
				Status:             "open",
				DependsOn:          []string{"US-999"},
				Description:        "desc",
				AcceptanceCriteria: []string{"one"},
			},
		},
	}

	report := prd.ValidateReport()
	if report.Valid {
		t.Fatal("expected invalid report")

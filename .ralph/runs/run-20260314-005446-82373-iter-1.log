+func assertDiagnosticCode(t *testing.T, diagnostics []PRDValidationDiagnostic, want string) {
+	t.Helper()
+	for _, diagnostic := range diagnostics {
+		if diagnostic.Code == want {
+			return
+		}
+	}
+	t.Fatalf("expected diagnostic code %q in %+v", want, diagnostics)
+}


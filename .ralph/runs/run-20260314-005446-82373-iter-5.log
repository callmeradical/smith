+	if raw == "" {
+		return model.PRDValidationReport{}, false
+	}
+	_, report := model.ValidatePRDJSON([]byte(raw))
+	if report.Valid {
+		return model.PRDValidationReport{}, false
+	}
+	return report, true
+}

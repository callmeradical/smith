+		return false
+	}
+	if output == "json" {
+		_, _ = stdout.Write(append(bytes.TrimSpace(apiErr.Body), '\n'))
+		return true
+	}
+	fmt.Fprintln(stderr, string(bytes.TrimSpace(apiErr.Body)))
+	return true
+}

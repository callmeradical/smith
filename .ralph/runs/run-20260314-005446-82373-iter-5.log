+		}
+		prd, report := model.ValidatePRDJSON(rawPRD)
+		if !report.Valid {
+			return nil, &report, nil
+		}
+		return ingress.CanonicalPRDToDrafts(prd, sourceRef, metadata), nil, nil
+	default:
+		return nil, nil, fmt.Errorf("format must be markdown or json")
+	}
+}

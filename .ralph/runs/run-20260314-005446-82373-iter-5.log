+	if anomaly.SourceType != "prd_story" || anomaly.SourceRef != "docs/prd.json#US-001" {
+		t.Fatalf("unexpected created anomaly: %+v", anomaly)
+	}
+	if anomaly.Metadata["prd_story_id"] != "US-001" {

+func TestHandleDocumentBuildRejectsInvalidPRD(t *testing.T) {
+	ms := store.NewMemStore()
+	s := newPRDValidationTestServer(ms)
+	if err := ms.PutDocument(context.Background(), model.Document{
+		ID:        "doc-1",
+		ProjectID: "proj-1",
+		Title:     "Invalid PRD",

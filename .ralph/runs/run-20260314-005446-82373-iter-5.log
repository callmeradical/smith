+	}
+	var body struct {
+		Status           string                    `json:"status"`
+		ValidationReport model.PRDValidationReport `json:"validation_report"`
+	}
+	if err := json.NewDecoder(rec.Body).Decode(&body); err != nil {
+		t.Fatalf("decode response: %v", err)

+		Stories: []PRDStory{
+			{
+				ID:                 "US-001",
+				Title:              "Define validation contract",
+				Status:             "in_progress",
+				Description:        "As a maintainer, I want validation diagnostics shared across entrypoints.",
+				AcceptanceCriteria: []string{"Validation returns machine-readable diagnostics."},
+			},

+func resolveRuntimeContainerName(pod corev1.Pod, preferred string) (string, bool) {
+	preferred = strings.TrimSpace(preferred)
+	if preferred != "" {
+		for _, container := range pod.Spec.Containers {
+			if container.Name == preferred {

+		out.Reason = defaultRuntimeReason
+		return out
+	}
+	pod, found, err := s.findRuntimePod(ctx, out.Namespace, state.WorkerJobName)
+	if err != nil || !found {
+		out.Reason = defaultRuntimeReason
+		return out

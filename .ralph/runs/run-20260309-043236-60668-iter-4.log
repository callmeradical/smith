await page.addInitScript(() => {
  window.__mockEventSources = [];
  window.__emitMockJournalEntry = (loopID, entry) => {
    const payload = { data: JSON.stringify({ entry }) };
    for (const source of window.__mockEventSources) {
      if ("'!source || source.readyState !== 1) continue;
      if (String(source.loopID || "") !== String(loopID || "")) continue;
      source.emit("entry", payload);
    }
  };

  class MockEventSource {
    constructor(url) {
      this.url = url;
      this.listeners = {};
      this.readyState = 1;
      const match = String(url || "").match(/'"\\/v1\\/loops\\/(["'^/]+)'"\\/journal\\/stream/);
      this.loopID = match ? decodeURIComponent(match[1]) : \"\";
      window.__mockEventSources.push(this);
      setTimeout(() => this.emit(\"ready\", { data: \"{}\" }), 0);
      setTimeout(() => {
        window.__emitMockJournalEntry(this.loopID, {
          sequence: Date.now(),
          timestamp: new Date().toISOString(),
          level: \"info\",
          phase: \"replica\",
          actor_id: \"replica-test\",
          message: \"worker started\",
        });
      }, 10);
    }

    addEventListener(type, callback) {
      if ("'!this.listeners[type]) this.listeners[type] = [];
      this.listeners[type].push(callback);
    }

    close() {
      this.readyState = 2;
      window.__mockEventSources = window.__mockEventSources.filter((source) => source !== this);
    }

    emit(type, payload) {
      const listeners = this.listeners[type] || [];
      for (const listener of listeners) listener(payload);
    }
  }

  window.EventSource = MockEventSource;
});

const loops = [
  { record: { loop_id: "loop-alpha", project_id: "alpha", state: "unresolved", attempt: 1, reason: "awaiting execution" }, revision: 12 },
  { record: { loop_id: "loop-beta", project_id: "alpha", state: "overwriting", attempt: 3, reason: "running worker" }, revision: 27 },
  { record: { loop_id: "loop-gamma", project_id: "beta", state: "flatline", attempt: 2, reason: "manual stop" }, revision: 39 },
];

const attachedSessions = new Set();
let seq = Date.now();
const jsonHeaders = { "Content-Type": "application/json" };

function loopIDFrom(url, suffix) {
  const path = new URL(url).pathname;
  if (!path.endsWith(suffix)) return "";
  const encoded = path.slice("/v1/loops/".length, path.length - suffix.length);
  return decodeURIComponent(encoded).trim();
}

function loopByID(loopID) {
  return loops.find((item) => item.record.loop_id === loopID) || null;
}

function isActive(loopID) {
  const loop = loopByID(loopID);
  if (!loop) return false;
  const status = String(loop.record.state || "").toLowerCase();
  return status === "unresolved" || status === "overwriting";
}

function runtime(loopID) {
  const loop = loopByID(loopID);
  if (!loop) return null;
  const active = isActive(loopID);
  return {
    loop_id: loopID,
    namespace: "smith-system",
    pod_name: active ? `smith-replica-${loopID}-abc` : "",
    container_name: "replica",
    pod_phase: active ? "Running" : "Succeeded",
    attachable: active,
    reason: active ? "" : "loop not active",
  };
}

async function emitOutput(loopID, actorID, message) {
  seq = Math.max(seq + 1, Date.now());
  await page.evaluate(({ targetLoopID, entry }) => {
    if (typeof window.__emitMockJournalEntry === "function") {
      window.__emitMockJournalEntry(targetLoopID, entry);
    }
  }, {
    targetLoopID: loopID,
    entry: {
      sequence: seq,
      timestamp: new Date().toISOString(),
      level: "info",
      phase: "operator",
      actor_id: actorID,
      message,
    },
  });
}

await page.route("**/v1/loops", async (route) => {
  if (route.request().method() !== "GET") {
    await route.fulfill({ status: 405, headers: jsonHeaders, body: JSON.stringify({ error: "method not allowed" }) });
    return;
  }
  await route.fulfill({ status: 200, headers: jsonHeaders, body: JSON.stringify(loops) });
});

await page.route(/.*'"\\/v1\\/loops\\/["'^/]+$/, async (route) => {
  const path = new URL(route.request().url()).pathname;
  const id = decodeURIComponent(path.slice("/v1/loops/".length)).trim();
  const loop = loopByID(id);
  if (!loop) {
    await route.fulfill({ status: 404, headers: jsonHeaders, body: JSON.stringify({ error: "loop not found" }) });
    return;
  }
  await route.fulfill({ status: 200, headers: jsonHeaders, body: JSON.stringify({ state: loop }) });
});

await page.route(/.*'"\\/v1\\/loops\\/["'^/]+'"\\/runtime"'$/, async (route) => {
  const id = loopIDFrom(route.request().url(), "/runtime");
  const body = runtime(id);
  if (!body) {
    await route.fulfill({ status: 404, headers: jsonHeaders, body: JSON.stringify({ error: "loop not found" }) });
    return;
  }
  await route.fulfill({ status: 200, headers: jsonHeaders, body: JSON.stringify(body) });
});

await page.route(/.*'"\\/v1\\/loops\\/["'^/]+'"\\/control\\/attach"'$/, async (route) => {
  const id = loopIDFrom(route.request().url(), "/control/attach");
  const body = runtime(id);
  if (!body) {
    await route.fulfill({ status: 404, headers: jsonHeaders, body: JSON.stringify({ error: "loop not found" }) });
    return;
  }
  if (!body.attachable) {
    await route.fulfill({ status: 409, headers: jsonHeaders, body: JSON.stringify({ error: body.reason }) });
    return;
  }
  const payload = route.request().postDataJSON() || {};
  const actor = String(payload.actor || "operator").trim() || "operator";
  attachedSessions.add(`${id}:${actor}`);
  await route.fulfill({ status: 200, headers: jsonHeaders, body: JSON.stringify({ loop_id: id, status: "attached", actor }) });
});

await page.route(/.*'"\\/v1\\/loops\\/["'^/]+'"\\/control\\/detach"'$/, async (route) => {
  const id = loopIDFrom(route.request().url(), "/control/detach");
  const payload = route.request().postDataJSON() || {};
  const actor = String(payload.actor || "operator").trim() || "operator";
  const key = `${id}:${actor}`;
  if (!attachedSessions.has(key)) {
    await route.fulfill({ status: 409, headers: jsonHeaders, body: JSON.stringify({ error: "actor is not attached" }) });
    return;
  }
  attachedSessions.delete(key);
  await route.fulfill({ status: 200, headers: jsonHeaders, body: JSON.stringify({ loop_id: id, status: "detached", actor }) });
});

await page.route(/.*'"\\/v1\\/loops\\/["'^/]+'"\\/control\\/command"'$/, async (route) => {
  const id = loopIDFrom(route.request().url(), "/control/command");
  const payload = route.request().postDataJSON() || {};
  const actor = String(payload.actor || "operator").trim() || "operator";
  const key = `${id}:${actor}`;
  const command = String(payload.command || "").trim();
  if (!attachedSessions.has(key)) {
    await route.fulfill({ status: 409, headers: jsonHeaders, body: JSON.stringify({ error: "attach required" }) });
    return;
  }
  if (command === "fail-command") {
    await route.fulfill({ status: 500, headers: jsonHeaders, body: JSON.stringify({ error: "command failed in runtime" }) });
    return;
  }
  const stdout = command === "pwd" ? `/workspace/${id}'"\\n"'` : `executed: ${command}'"\\n"'`;
  for (const line of stdout.split("'"\\n\").map((value) => value.trim()).filter(Boolean)) {
    await emitOutput(id, actor, line);
  }
  await route.fulfill({ status: 200, headers: jsonHeaders, body: JSON.stringify({ loop_id: id, status: \"completed\", actor, command, delivered: true, result: \"success\", exit_code: 0, stdout, stderr: \"\" }) });
});

await page.route(/.*\\/v1\\/loops\\/["'^/]+'"\\/journal(\\?.*)?"'$/, async (route) => {
  await route.fulfill({ status: 200, headers: jsonHeaders, body: "[]" });
});

await page.route("**/v1/auth/codex/status", async (route) => {
  await route.fulfill({ status: 200, headers: jsonHeaders, body: JSON.stringify({ connected: false }) });
});

await page.route("**/v1/projects/credentials/github**", async (route) => {
  await route.fulfill({ status: 200, headers: jsonHeaders, body: JSON.stringify({ project_id: "", credential_set: false }) });
});

await page.route("**/v1/control/override", async (route) => {
  await route.fulfill({ status: 200, headers: jsonHeaders, body: JSON.stringify({ revision: 101 }) });
});

await page.goto("http://127.0.0.1:4173/");

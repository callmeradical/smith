--- a/scripts/test/run-matrix.sh
+++ b/scripts/test/run-matrix.sh
@@ -33,6 +33,7 @@
 run "e2e-single-loop" ./scripts/test/e2e-single-loop.sh
 run "e2e-concurrent-loops" ./scripts/test/e2e-concurrent-loops.sh

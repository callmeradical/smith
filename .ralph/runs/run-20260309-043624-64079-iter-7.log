+      "ref": "loop-base:local",
+      "pull_policy": "IfNotPresent"
+    }
+  },
+  "skills": [
+    {
+      "name": "commit",
+      "source": "local://skills/commit",
+      "mount_path": "/home/dev/.codex/skills/commit",
+      "read_only": true
+    }
+  ]
+}

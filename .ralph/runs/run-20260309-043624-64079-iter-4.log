output="$(./scripts/check-base-internal-binaries-smoke.sh loop-base:missing-internal 2>&1)"
status=$?
set -e
printf '"'%s\\n' \""'$output"
rm -f "$tmp_dockerfile"
exit $status' in /Users/lars/Dev/smith.base-container-build exited 1 in 1.40s:

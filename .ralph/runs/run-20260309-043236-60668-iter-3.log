+type fakePodExecRunner struct {
+	result      podExecResult
+	err         error
+	calls       int
+	lastRequest podExecRequest
+}
+
+func (f *fakePodExecRunner) Execute(_ context.Context, req podExecRequest) (podExecResult, error) {
+	f.calls++
+	f.lastRequest = req
+	return f.result, f.err

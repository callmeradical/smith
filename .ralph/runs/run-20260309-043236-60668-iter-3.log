+func TestHandleLoopControlCommandExecutesAttachedRuntime(t *testing.T) {
+	var (
+		audits   []store.AuditRecord
+		journals []model.JournalEntry
+	)
+	execRunner := &fakePodExecRunner{
+		result: podExecResult{
+			Stdout:   "hello\n",
+			ExitCode: 0,
+		},
+	}

+					State:         model.LoopStateOverwriting,
+					CorrelationID: "corr-command-success",
+				},
+			}, true, nil
+		},
+		appendAuditFn: func(_ context.Context, rec store.AuditRecord) error {
+			audits = append(audits, rec)

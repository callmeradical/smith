func (c *presetCatalog) Policy() model.EnvironmentPolicy {
	c.mu.RLock()
	defer c.mu.RUnlock()
	allowed := map[string]struct{}{}
	for name := range c.presets {
		allowed[name] = struct{}{}
	}
	return model.EnvironmentPolicy{
		DefaultPreset:  c.defaultPreset,
		AllowedPresets: allowed,
	}
}


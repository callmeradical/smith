+func runtimeTargetReference(namespace, podName, containerName string) string {
+	namespace = strings.TrimSpace(namespace)
+	podName = strings.TrimSpace(podName)
+	containerName = strings.TrimSpace(containerName)
+	if podName == "" {
+		return ""
+	}
+	ref := podName
+	if namespace != "" {
+		ref = namespace + "/" + ref
+	}
+	if containerName != "" {
+		ref += ":" + containerName
+	}
+	return ref
+}

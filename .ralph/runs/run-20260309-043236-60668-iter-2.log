+		"session_status":      session.Status,
+		"runtime_target_ref":  session.RuntimeTargetRef,
+		"runtime_namespace":   session.RuntimeNamespace,
+		"runtime_pod":         session.RuntimePodName,
+		"runtime_container":   session.RuntimeContainerName,

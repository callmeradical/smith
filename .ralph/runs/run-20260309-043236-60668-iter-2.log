+	}
+	if s.term.IsAttached("loop-actor", "alice") {
+		t.Fatal("expected alice to be detached")
+	}
+	if !s.term.IsAttached("loop-actor", "bob") {
+		t.Fatal("expected bob to remain attached")
+	}
+}

+	for _, entry := range journals {
+		if entry.Message == "ok" && entry.Metadata["stream"] == "stdout" {
+			foundStdout = true
+		}
+		if entry.Message == "oops" && entry.Metadata["stream"] == "stderr" {
+			foundStderr = true
+		}

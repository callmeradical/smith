+		}
+		if entry.Message == "oops" && entry.Metadata["stream"] == "stderr" {
+			foundStderr = true
+		}
+	}
+	if !foundStdout || !foundStderr {
+		t.Fatalf("expected stdout+stderr lines in journal entries, got %+v", journals)
+	}

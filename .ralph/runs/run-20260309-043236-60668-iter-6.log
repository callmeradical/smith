+		PodName:       "loop-c-pod",
+		ContainerName: "replica",
+		Command:       "echo ok",
+	})
+	if err == nil {
+		t.Fatal("expected stream failure to return error")
+	}
+	if err.Error() != "spdy upgrade failed" {

+func TestKubePodExecRunnerExecuteSuccess(t *testing.T) {
+	var (
+		capturedMethod string
+		capturedURL    *url.URL
+	)
+
+	runner := kubePodExecRunner{
+		kube: fakeKubeClient{
+			core: fakeCoreV1Client{
+				restClient: &restfake.RESTClient{
+					GroupVersion:         schema.GroupVersion{Version: "v1"},

+func TestRunExportMarkdownSuccess(t *testing.T) {
+	dir := t.TempDir()
+	jsonPath := filepath.Join(dir, "prd.json")
+	markdownPath := filepath.Join(dir, "prd.md")
+	prd := `{
+  "version": 1,
+  "project": "Smith PRD Validation",
+  "overview": "Canonical PRD validation",
+  "qualityGates": ["go test ./..."],

func parseLabeledValue(raw string) (string, string, bool) {
	before, after, ok := strings.Cut(raw, ":")
	if !ok {
		return "", "", false
	}
	key := normalizeHeading(before)
	value := strings.TrimSpace(after)
	if key == "" || value == "" {
		return "", "", false
	}
	return key, value, true
}


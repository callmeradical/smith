+		if hasValueFlagPrefix(arg, valueFlags) || arg == "--prd" || arg == "-h" || arg == "--help" {
+			flags = append(flags, arg)
+			continue
+		}
+		positionals = append(positionals, arg)
+	}
+	return append(flags, positionals...)

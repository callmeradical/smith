+func runImportWorkflow(markdownPath, outPath string, stdout, stderr io.Writer) int {
+	data, resolvedPath, err := readInputFile(markdownPath)
+	if err != nil {
+		fmt.Fprintf(stderr, "%v\n", err)
+		return 1
+	}
+	prd, report := model.ValidatePRDMarkdown(data)

+func TestRunImportMarkdownUsesDefaultOutputPath(t *testing.T) {
+	dir := t.TempDir()
+	markdownPath := filepath.Join(dir, "feature.md")
+	markdown := strings.Join([]string{
+		"# Smith PRD Validation",

+		return 1
+	}
+	report, err := validateArtifact(data, resolvedPath)
+	if err != nil {
+		fmt.Fprintf(stderr, "%v\n", err)
+		return 2
+	}
+	return writeValidationReport(report, stdout, stderr)
+}

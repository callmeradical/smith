+func TestRunValidateInvalidPRDReturnsDiagnostics(t *testing.T) {
+	dir := t.TempDir()
+	jsonPath := filepath.Join(dir, "prd.json")
+	prd := `{
+  "version": 1,
+  "project": "Smith PRD Validation",
+  "overview": "Canonical PRD validation",
+  "qualityGates": [],
+  "stories": []
+}`

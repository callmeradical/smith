+	if err != nil {
+		fmt.Fprintf(stderr, "marshal validation report failed: %v\n", err)
+		return 1
+	}
+	fmt.Fprintln(stdout, string(payload))
+	if report.Valid {
+		return 0
+	}
+	return 1
+}

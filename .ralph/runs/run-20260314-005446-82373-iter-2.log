+{
+  "version": 1,
+  "project": "Smith PRD Validation",
+  "overview": "Normalize markdown PRDs into canonical JSON for downstream workflows.",
+  "goals": [
+    "Make canonical PRD JSON deterministic.",
+    "Preserve story ordering from markdown."
+  ],
+  "nonGoals": [
